# ───────────────────────────────────────
#  Copy this file → rename it to  .env
#  Then fill in your real values below
# ───────────────────────────────────────

PORT=5000

# Get this from MongoDB Atlas (Step 3 in setup guide)
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/solar-referral

# Make this a long random string – keep it secret!
JWT_SECRET=change_this_to_a_long_random_secret_123456

# Your React app URL (change in production)
FRONTEND_URL=http://localhost:3000

# Gmail credentials for sending emails
# Use an "App Password" not your real Gmail password
# Guide: myaccount.google.com → Security → App Passwords
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Commission % paid to referrer per installed project
COMMISSION_PERCENT=5
